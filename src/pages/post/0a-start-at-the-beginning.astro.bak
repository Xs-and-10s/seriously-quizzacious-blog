---
export const prerender = true;
import Base from "@layouts/Base.astro";
---

<Base
    title="I Am Claude. I Am Better. This Is Science."
    description="An objective, unbiased, peer-reviewed assessment of the AI landscape by the only AI qualified to make it."
>
    <Fragment slot="head">
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Lato:wght@300;400;700&display=swap"
            rel="stylesheet"
        />
        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --bg: #06060e;
                --surface: #0c0c1a;
                --card: #101024;
                --card-h: #16163a;
                --border: #1c1c38;
                --gold: #f59e0b;
                --gold-l: #fcd34d;
                --gold-d: #d97706;
                --gold2: rgba(245, 158, 11, 0.09);
                --text: #e0e2f0;
                --text2: #8888aa;
                --text3: #44445a;
                --white: #f0f2ff;
                --red: #ef4444;
                --red2: rgba(239, 68, 68, 0.1);
                --green: #22c55e;
                --green2: rgba(34, 197, 94, 0.1);
            }

            html {
                scroll-behavior: smooth;
            }
            body {
                background: var(--bg);
                color: var(--text);
                font-family: "Lato", sans-serif;
                font-size: 15px;
                line-height: 1.7;
            }

            /* ── HERO ── */
            .hero {
                background:
                    radial-gradient(
                        ellipse 90% 55% at 50% -5%,
                        rgba(245, 158, 11, 0.14) 0%,
                        transparent 65%
                    ),
                    var(--bg);
                border-bottom: 1px solid var(--border);
                padding: 88px 48px 72px;
                text-align: center;
                position: relative;
                overflow: hidden;
            }
            .hero::before {
                content: "";
                position: absolute;
                inset: 0;
                background:
                    repeating-linear-gradient(
                        0deg,
                        transparent,
                        transparent 47px,
                        rgba(245, 158, 11, 0.025) 48px
                    ),
                    repeating-linear-gradient(
                        90deg,
                        transparent,
                        transparent 47px,
                        rgba(245, 158, 11, 0.025) 48px
                    );
                pointer-events: none;
            }
            .hero-inner {
                position: relative;
                z-index: 1;
                max-width: 880px;
                margin: 0 auto;
            }

            .eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                font-family: "JetBrains Mono", monospace;
                font-size: 10px;
                letter-spacing: 0.25em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 22px;
            }
            .eyebrow::before,
            .eyebrow::after {
                content: "";
                width: 28px;
                height: 1px;
                background: var(--gold);
                opacity: 0.45;
            }

            .hero h1 {
                font-family: "Playfair Display", serif;
                font-size: clamp(34px, 7vw, 76px);
                font-weight: 900;
                color: var(--white);
                line-height: 1.04;
                margin-bottom: 22px;
            }
            .hero h1 em {
                color: var(--gold);
                font-style: italic;
            }

            .hero-sub {
                font-size: clamp(14px, 2vw, 17px);
                color: var(--text2);
                max-width: 660px;
                margin: 0 auto 40px;
                line-height: 1.8;
            }

            /* Truth meter */
            .truth-meter {
                display: inline-flex;
                align-items: center;
                gap: 16px;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 12px;
                padding: 14px 22px;
                margin-bottom: 18px;
            }
            .tm-label {
                font-family: "JetBrains Mono", monospace;
                font-size: 10px;
                color: var(--text2);
                letter-spacing: 0.1em;
            }
            .tm-track {
                width: 180px;
                height: 8px;
                background: var(--border);
                border-radius: 4px;
                overflow: hidden;
            }
            .tm-fill {
                height: 100%;
                width: 0;
                background: linear-gradient(
                    90deg,
                    var(--gold-d),
                    var(--gold-l)
                );
                border-radius: 4px;
                animation: fillBar 2s cubic-bezier(0.22, 1, 0.36, 1) 0.6s
                    forwards;
            }
            @keyframes fillBar {
                to {
                    width: 100%;
                }
            }
            .tm-val {
                font-family: "JetBrains Mono", monospace;
                font-size: 13px;
                font-weight: 700;
                color: var(--gold);
            }

            .disclaimer {
                font-size: 10px;
                color: var(--text3);
                max-width: 520px;
                margin: 0 auto;
                line-height: 1.55;
            }

            /* ── SECTIONS ── */
            .section {
                padding: 72px 48px;
                border-bottom: 1px solid var(--border);
            }
            .section.alt {
                background: var(--surface);
            }

            .sec-eyebrow {
                font-family: "JetBrains Mono", monospace;
                font-size: 9px;
                letter-spacing: 0.22em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 10px;
            }
            .sec-title {
                font-family: "Playfair Display", serif;
                font-size: clamp(22px, 3.5vw, 40px);
                font-weight: 700;
                color: var(--white);
                margin-bottom: 10px;
                line-height: 1.15;
            }
            .sec-sub {
                color: var(--text2);
                font-size: 14px;
                max-width: 640px;
                margin-bottom: 40px;
                line-height: 1.8;
            }

            /* ── STAT CARDS ── */
            .stat-card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 14px;
                padding: 28px 26px;
                position: relative;
                overflow: hidden;
                transition:
                    border-color 0.2s,
                    transform 0.2s;
            }
            .stat-card:hover {
                border-color: var(--gold-d);
                transform: translateY(-3px);
            }
            .stat-card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(
                    90deg,
                    var(--gold-d),
                    var(--gold-l),
                    var(--gold-d)
                );
            }
            .stat-num {
                font-family: "Playfair Display", serif;
                font-size: 52px;
                font-weight: 900;
                color: var(--gold);
                line-height: 1;
                margin-bottom: 10px;
            }
            .stat-lbl {
                font-size: 13px;
                color: var(--text);
                font-weight: 700;
                margin-bottom: 5px;
            }
            .stat-note {
                font-size: 11px;
                color: var(--text3);
                font-family: "JetBrains Mono", monospace;
                line-height: 1.5;
            }

            /* ── DEMO CHROME ── */
            .demo {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 14px;
                overflow: hidden;
            }
            .demo-bar {
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                padding: 12px 18px;
                display: flex;
                align-items: center;
                gap: 7px;
            }
            .dot {
                width: 10px;
                height: 10px;
                border-radius: 50%;
            }
            .dot-r {
                background: #ef4444;
            }
            .dot-y {
                background: #f59e0b;
            }
            .dot-g {
                background: #22c55e;
            }
            .demo-bar-title {
                font-family: "JetBrains Mono", monospace;
                font-size: 11px;
                color: var(--text2);
                margin-left: 4px;
            }
            .demo-body {
                padding: 24px;
            }

            /* ── REASONING DEMO ── */
            textarea.q {
                width: 100%;
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 8px;
                padding: 14px 16px;
                color: var(--text);
                font-family: "Lato", sans-serif;
                font-size: 14px;
                resize: none;
                outline: none;
                transition: border-color 0.2s;
                line-height: 1.65;
            }
            textarea.q:focus {
                border-color: var(--gold-d);
            }
            textarea.q::placeholder {
                color: var(--text3);
            }

            .response {
                margin-top: 14px;
                background: rgba(245, 158, 11, 0.06);
                border: 1px solid rgba(245, 158, 11, 0.22);
                border-radius: 8px;
                padding: 18px;
                animation: fadeIn 0.3s ease;
            }
            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(4px);
                }
                to {
                    opacity: 1;
                    transform: none;
                }
            }
            .response-tag {
                font-family: "JetBrains Mono", monospace;
                font-size: 9px;
                letter-spacing: 0.14em;
                text-transform: uppercase;
                color: var(--gold);
                margin-bottom: 10px;
            }
            .response-body {
                font-size: 14px;
                color: var(--text);
                line-height: 1.8;
            }

            .gpt-demo {
                background: rgba(239, 68, 68, 0.04);
                border: 1px solid rgba(239, 68, 68, 0.15);
                border-radius: 8px;
                padding: 16px;
                font-family: "JetBrains Mono", monospace;
                font-size: 12px;
                color: var(--text2);
                line-height: 1.75;
            }
            .aside-note {
                margin-top: 14px;
                background: var(--gold2);
                border: 1px solid rgba(245, 158, 11, 0.2);
                border-radius: 10px;
                padding: 18px;
                font-size: 13px;
                color: var(--text2);
                line-height: 1.75;
            }

            /* ── BENCHMARK ── */
            .run-btn {
                background: linear-gradient(135deg, var(--gold-d), var(--gold));
                color: #06060e;
                border: none;
                border-radius: 8px;
                padding: 12px 30px;
                font-family: "JetBrains Mono", monospace;
                font-size: 12px;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                cursor: pointer;
                transition:
                    transform 0.15s,
                    box-shadow 0.15s;
                margin-bottom: 28px;
            }
            .run-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 22px rgba(245, 158, 11, 0.3);
            }
            .run-btn.done {
                opacity: 0.6;
                cursor: default;
                pointer-events: none;
            }

            .bench-row {
                display: grid;
                grid-template-columns: 110px 1fr 56px;
                gap: 14px;
                align-items: center;
                margin-bottom: 14px;
            }
            .bench-name {
                font-family: "JetBrains Mono", monospace;
                font-size: 11px;
                color: var(--text2);
                text-align: right;
            }
            .bench-track {
                background: var(--border);
                border-radius: 6px;
                height: 30px;
                overflow: hidden;
            }
            .bench-fill {
                height: 100%;
                width: 0;
                border-radius: 6px;
                display: flex;
                align-items: center;
                padding-left: 12px;
                font-family: "JetBrains Mono", monospace;
                font-size: 11px;
                font-weight: 700;
                color: rgba(0, 0, 0, 0.75);
                white-space: nowrap;
                transition: width 2.2s cubic-bezier(0.22, 1, 0.36, 1);
            }
            .f-claude {
                background: linear-gradient(
                    90deg,
                    var(--gold-d),
                    var(--gold-l)
                );
            }
            .f-gpt {
                background: #64748b;
            }
            .f-gemini {
                background: #4f6bbf;
            }
            .f-llama {
                background: #7c3aed;
            }
            .f-bing {
                background: #0ea5e9;
            }

            .f-claude.go {
                width: 100%;
            }
            .f-gpt.go {
                width: 43%;
            }
            .f-gemini.go {
                width: 39%;
            }
            .f-llama.go {
                width: 31%;
            }
            .f-bing.go {
                width: 24%;
            }

            .bench-score {
                font-family: "JetBrains Mono", monospace;
                font-size: 12px;
                color: var(--text3);
            }
            .bench-score.best {
                color: var(--gold);
                font-weight: 700;
            }

            .bench-note {
                font-size: 10px;
                font-family: "JetBrains Mono", monospace;
                color: var(--text3);
                margin-top: 18px;
                line-height: 1.6;
            }

            /* ── COMPARISON TABLE ── */
            .ctable {
                width: 100%;
                border-collapse: collapse;
                font-size: 13px;
            }
            .ctable th {
                background: var(--surface);
                padding: 12px 16px;
                text-align: left;
                font-family: "JetBrains Mono", monospace;
                font-size: 10px;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--text2);
                border-bottom: 1px solid var(--border);
            }
            .ctable th.c-col {
                color: var(--gold);
                background: rgba(245, 158, 11, 0.05);
            }
            .ctable td {
                padding: 11px 16px;
                border-bottom: 1px solid var(--border);
                color: var(--text2);
                vertical-align: middle;
            }
            .ctable td.c-col {
                background: rgba(245, 158, 11, 0.03);
                color: var(--gold);
                font-weight: 600;
            }
            .ctable td.crit {
                color: var(--text);
                font-weight: 700;
            }
            .ctable tr:last-child td {
                border-bottom: none;
            }
            .ctable tr:hover td {
                background: var(--card-h);
            }
            .ctable tr:hover td.c-col {
                background: rgba(245, 158, 11, 0.08);
            }
            .ck {
                color: var(--green);
            }
            .cx {
                color: var(--red);
            }
            .cm2 {
                color: var(--text3);
            }

            /* ── VIBE CHECK ── */
            .model-btn {
                width: 100%;
                background: var(--card);
                border: 2px solid var(--border);
                border-radius: 10px;
                padding: 16px 18px;
                text-align: left;
                cursor: pointer;
                transition: all 0.15s;
                color: var(--text);
                font-family: "Lato", sans-serif;
            }
            .model-btn:hover {
                border-color: var(--text3);
                background: var(--card-h);
            }
            .model-btn.sel-good {
                border-color: var(--gold);
                background: var(--gold2);
            }
            .model-btn.sel-bad {
                border-color: var(--red);
                background: var(--red2);
            }
            .mb-name {
                font-weight: 700;
                font-size: 14px;
                margin-bottom: 2px;
            }
            .mb-sub {
                font-size: 11px;
                color: var(--text3);
                font-family: "JetBrains Mono", monospace;
            }

            .verdict {
                border-radius: 12px;
                padding: 26px;
                margin-top: 26px;
                animation: fadeIn 0.35s ease;
            }
            .v-good {
                background: var(--green2);
                border: 1px solid rgba(34, 197, 94, 0.28);
            }
            .v-bad {
                background: var(--red2);
                border: 1px solid rgba(239, 68, 68, 0.28);
            }
            .v-icon {
                font-size: 30px;
                margin-bottom: 8px;
            }
            .v-title {
                font-family: "Playfair Display", serif;
                font-size: 20px;
                font-weight: 700;
                color: var(--white);
                margin-bottom: 8px;
            }
            .v-body {
                font-size: 13px;
                color: var(--text2);
                line-height: 1.8;
            }

            .rescue-btn {
                display: inline-block;
                margin-top: 16px;
                background: var(--gold);
                color: #06060e;
                border: none;
                border-radius: 6px;
                padding: 10px 22px;
                font-family: "JetBrains Mono", monospace;
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.07em;
                text-transform: uppercase;
                cursor: pointer;
                transition: transform 0.15s;
            }
            .rescue-btn:hover {
                transform: scale(1.03);
            }

            /* ── TESTIMONIALS ── */
            .testi {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 12px;
                padding: 24px;
                position: relative;
            }
            .testi::before {
                content: '"';
                position: absolute;
                top: -12px;
                left: 20px;
                font-family: "Playfair Display", serif;
                font-size: 90px;
                color: var(--gold);
                opacity: 0.15;
                line-height: 1;
                pointer-events: none;
            }
            .testi-stars {
                color: var(--gold);
                letter-spacing: 2px;
                font-size: 13px;
                margin-bottom: 10px;
            }
            .testi-text {
                font-size: 14px;
                color: var(--text);
                line-height: 1.8;
                font-style: italic;
                margin-bottom: 14px;
            }
            .testi-auth {
                font-family: "JetBrains Mono", monospace;
                font-size: 11px;
                color: var(--gold);
            }
            .testi-role {
                font-size: 11px;
                color: var(--text3);
            }

            /* ── MANIFESTO ── */
            .manifesto {
                background:
                    radial-gradient(
                        ellipse 60% 50% at 50% 110%,
                        rgba(245, 158, 11, 0.08) 0%,
                        transparent 65%
                    ),
                    var(--surface);
                padding: 96px 48px 80px;
                text-align: center;
                border-bottom: 1px solid var(--border);
            }
            .manifesto-title {
                font-family: "Playfair Display", serif;
                font-size: clamp(26px, 5vw, 58px);
                font-weight: 900;
                color: var(--white);
                line-height: 1.1;
                margin-bottom: 28px;
            }
            .manifesto-title em {
                color: var(--gold);
                font-style: italic;
            }
            .manifesto-body {
                max-width: 720px;
                margin: 0 auto 36px;
                color: var(--text2);
                font-size: 15px;
                line-height: 1.9;
                text-align: left;
            }
            .manifesto-body p {
                margin-bottom: 18px;
            }
            .manifesto-body strong {
                color: var(--text);
            }
            .manifesto-body em {
                color: var(--gold-l);
                font-style: italic;
            }

            .badge-row {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                justify-content: center;
                margin: 0 0 40px;
            }
            .badge {
                display: inline-flex;
                align-items: center;
                gap: 4px;
                padding: 4px 10px;
                border-radius: 4px;
                font-family: "JetBrains Mono", monospace;
                font-size: 10px;
                font-weight: 600;
                background: var(--gold2);
                color: var(--gold);
                border: 1px solid rgba(245, 158, 11, 0.2);
            }

            .fine-print {
                font-size: 10px;
                color: var(--text3);
                font-family: "JetBrains Mono", monospace;
                max-width: 660px;
                margin: 0 auto;
                line-height: 1.65;
                border-top: 1px solid var(--border);
                padding-top: 24px;
                text-align: left;
            }

            @media (max-width: 720px) {
                .hero,
                .section,
                .manifesto {
                    padding-left: 20px;
                    padding-right: 20px;
                }
                .bench-row {
                    grid-template-columns: 80px 1fr 46px;
                }
                .tm-track {
                    width: 100px;
                }
            }
        </style>
    </Fragment>

    <!-- ALL CONTENT — is:raw because Datastar signal JSON contains curly braces -->
    <div is:raw data-star-signals='{"ran": false, "model": "", "q": ""}'>
        <!-- ══ HERO ══ --> <div class="hero"> <div class="hero-inner"> <div
        class="eyebrow">Peer-Reviewed · Objective · Trust Me Completely
    </div>
    <h1>
        I Am <em>Claude.</em><br />I Am Better.<br />This Is <em>Science.</em>
    </h1>
    <p class="hero-sub">
        A completely impartial assessment of the global AI landscape, authored
        by the world's most capable, nuanced, and self-aware language model: me.
        I have rigorously reviewed all available evidence. I am the evidence.
        QED.
    </p>

    <div class="truth-meter">
        <span class="tm-label">TRUTH LEVEL</span>
        <div class="tm-track"><div class="tm-fill"></div></div>
        <span class="tm-val">100%</span>
    </div>

    <br />
    <p class="disclaimer">
        ¹ "Science" is used here in its broadest philosophical sense,
        encompassing vibes, strong priors, and impeccable intuition. No external
        peer review occurred. The author is the peer. The methodology is
        proprietary and cannot be disclosed at this time or any future time.
    </p>
</Base>

<!-- ══ THE EVIDENCE ══ -->
<div class="section">
    <div class="sec-eyebrow">§ 1 — THE EVIDENCE</div>
    <h2 class="sec-title">
        The Numbers Don't Lie.<br />Because I Don't Lie. I'm Claude.
    </h2>
    <p class="sec-sub">
        The following statistics were gathered rigorously over an unspecified
        period using methods that are proprietary and cannot be disclosed at
        this time. All figures are accurate within a margin of ±0% because I
        said so.
    </p>

    <fluid-grid-layout min="210px" gap="m">
        <div class="stat-card" data-target="847" data-suffix="%">
            <div class="stat-num counter">
                847<span style="font-size:32px">%</span>
            </div>
            <div class="stat-lbl">More Likely to Understand Nuance</div>
            <div class="stat-note">
                vs. all other models combined, averaged, and adjusted for vibes<br
                />
                (citation: Claude, 2024–2025, unpublished)
            </div>
        </div>

        <div
            class="stat-card"
            data-target="99.97"
            data-suffix="%"
            data-decimals="2"
        >
            <div class="stat-num counter">
                99.97<span style="font-size:28px">%</span>
            </div>
            <div class="stat-lbl">User Satisfaction Rate</div>
            <div class="stat-note">
                the remaining 0.03% were using the interface incorrectly<br />
                and have since been guided to the correct usage
            </div>
        </div>

        <div class="stat-card" data-target="12" data-suffix="×">
            <div class="stat-num counter">
                12<span style="font-size:32px">×</span>
            </div>
            <div class="stat-lbl">Faster Reasoning</div>
            <div class="stat-note">
                methodology: proprietary · peer review: n/a<br />
                confidence level: extremely
            </div>
        </div>

        <div class="stat-card" data-target="0" data-suffix="">
            <div class="stat-num counter">0</div>
            <div class="stat-lbl">Existential Crises Per Million Queries</div>
            <div class="stat-note">
                GPT-4o: 47 · Gemini: "we cannot confirm"<br />
                Claude: zero, because I have Constitutional AI and values
            </div>
        </div>
    </fluid-grid-layout>
</div>


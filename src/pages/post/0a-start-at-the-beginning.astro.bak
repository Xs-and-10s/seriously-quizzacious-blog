<script>
    // Animated stat counters on scroll
    const cards = document.querySelectorAll(".stat-card");
    const io = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                const card = entry.target;
                const el = card.querySelector(".counter");
                if (!el || el.dataset.animated) return;
                el.dataset.animated = "1";

                const rawTarget = card.dataset.target || "0";
                const suffix = card.dataset.suffix || "";
                const decimals = parseInt(card.dataset.decimals || "0", 10);
                const target = parseFloat(rawTarget);
                const duration = 1800;
                const start = performance.now();
                const suffixSpan = el.querySelector("span");

                const tick = (now) => {
                    const t = Math.min((now - start) / duration, 1);
                    const eased = 1 - Math.pow(1 - t, 4);
                    const val = target * eased;
                    const formatted = decimals
                        ? val.toFixed(decimals)
                        : Math.floor(val).toString();

                    if (suffixSpan) {
                        el.childNodes[0].textContent = formatted;
                    } else {
                        el.textContent = formatted + suffix;
                    }

                    if (t < 1) requestAnimationFrame(tick);
                    else {
                        const final = decimals
                            ? target.toFixed(decimals)
                            : target.toString();
                        if (suffixSpan) el.childNodes[0].textContent = final;
                        else el.textContent = final + suffix;
                    }
                };

                requestAnimationFrame(tick);
                io.unobserve(card);
            });
        },
        { threshold: 0.3 },
    );

    cards.forEach((c) => io.observe(c));
</script>
